{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "staff", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Service": {
      "title": "Service",
      "description": "Grooming or spa service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string", "enum": ["Barbering", "Hair Salon", "Spa"] },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "category", "price", "duration"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Appointment booking",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "serviceId": { "type": "string" },
        "staffId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "cancelled", "completed"] },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "serviceId", "date", "status"]
    },
    "Staff": {
      "title": "Staff",
      "description": "Salon staff member",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "specialization": { "type": "string" },
        "bio": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "name"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Available services"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Appointment records"
    },
    "/staff/{staffId}": {
      "schema": "Staff",
      "description": "Staff profiles"
    }
  }
}
